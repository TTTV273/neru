{
  "experimental": {
    "enableAgents": true
  },
  "mcpServers": {
    "neo4j-cypher": {
      "command": "uvx",
      "args": [
        "--with",
        "fastmcp<2.11.4",
        "mcp-neo4j-cypher@0.5.1",
        "--transport",
        "stdio"
      ],
      "env": {
        "NEO4J_URI": "bolt://localhost:7687",
        "NEO4J_USERNAME": "neo4j",
        "NEO4J_PASSWORD": "password123",
        "NEO4J_DATABASE": "neo4j"
      }
    },
    "neo4j-memory": {
      "command": "uvx",
      "args": [
        "--with",
        "fastmcp<2.11.4",
        "mcp-neo4j-memory@0.4.3"
      ],
      "env": {
        "NEO4J_URI": "bolt://localhost:7687",
        "NEO4J_USERNAME": "neo4j",
        "NEO4J_PASSWORD": "password123",
        "NEO4J_DATABASE": "neo4j"
      }
    }
  }
}
